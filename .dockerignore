# =========================================================================
# .dockerignore · 爱的小窝
# 仅排除构建上下文无关文件，减少传给 Docker daemon 的体积、加快构建
# 运行时所需的静态资源（HTML/CSS/JS/图片/音频/JSON）全部保留
# =========================================================================

# ---------- 版本控制 ----------
.git/
.gitignore

# ---------- CI / IDE / 本地工具配置 ----------
.github/
.trae/
.vscode/
.idea/
*.swp
*.swo
.workbuddy/

# ---------- 系统文件 ----------
.DS_Store
Thumbs.db

# ---------- 临时 / 备份 / 日志 ----------
*.tmp
*.log
*.backup
*.bak

# ---------- 文档（运行时不需要，只服务于开发） ----------
README.md

# ---------- Docker 自身（避免递归拷贝） ----------
Dockerfile
.dockerignore
